# System files
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
Icon\r

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime / dependency directories
node_modules/
vendor/
.pip-wheel-metadata/

# Build output
dist/
build/
out/
target/

# Environment files
.env
.env.*
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.pytest_cache/

# Java
*.class
*.jar
*.war
*.ear

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
vendor/

# .NET
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# IDEs
.vscode/
.idea/
*.iml
*.ipr
*.iws
.cache/

# JetBrains Rider
.idea/
*.sln.iml

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.swp
*.swo
*~

# Coverage
coverage/
coverage-final.json
*.lcov

# Dependency directories
.pnp/
.pnp.js

# Lockfiles (optional - keep if you want to track)
# package-lock.json
# yarn.lock

# Misc
.firebase/
.terraform/
.serverless/
__pycache__/

# Ignore secrets and keys
*.pem
*.key
*.crt

# Ignore IDE/workspace specific files
.idea/
.vscode/
*.log

# Custom ignore files
.specify
.claude
